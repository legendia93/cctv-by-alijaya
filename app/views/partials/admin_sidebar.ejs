<%
// ========== HELPER FUNCTIONS ==========
function renderMenuItem(basePath, href, pageName, currentPage, iconPath, label, isNew) {
    const active = currentPage === pageName ? 'active' : '';
    const newBadge = isNew ? '<span class="n-new ml-auto shrink-0">NEW</span>' : '';
    return `<a href="${basePath}/${href}" class="nav-link ${active}" data-title="${label}">
        <div class="nav-icon"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">${iconPath}</svg></div>
        <span class="sidebar-text">${label}</span>
        ${newBadge}
    </a>`;
}

function renderExternalLink(href, label, iconPath) {
    return `<a href="${href}" target="_blank" class="nav-link" data-title="${label}">
        <div class="nav-icon"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">${iconPath}</svg></div>
        <span class="sidebar-text">${label}</span>
        <svg class="nav-ext" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
    </a>`;
}
%>
<!-- ============================================================ -->
<!-- SIDEBAR — Nothing OS: flat, monokrom, garis 1px               -->
<!-- ============================================================ -->
<aside id="adminSidebar" class="flex-col relative z-40 hidden md:flex" style="width:256px;min-width:256px;background:var(--n-surface);border-right:1px solid var(--n-line);transition:width 0.35s cubic-bezier(0.4,0,0.2,1), min-width 0.35s cubic-bezier(0.4,0,0.2,1);">

    <!-- ========== HEADER + TOGGLE ========== -->
    <div class="h-16 flex items-center justify-between px-4 shrink-0" style="border-bottom:1px solid var(--n-line);">
        <div class="flex items-center gap-3 overflow-hidden" id="logoContainer">
            <!-- Dot-mark monokrom -->
            <div class="n-logomark shrink-0">
                <span></span><span></span><span></span>
                <span></span><span class="dot-accent"></span><span></span>
                <span></span><span></span><span></span>
            </div>
            <span id="logoText" class="text-sm whitespace-nowrap" style="font-family:var(--font-dot);letter-spacing:.1em;color:var(--n-ink);transition:opacity .25s ease;">CCTV</span>
        </div>

        <button onclick="toggleSidebar()" id="sidebarToggleBtn" class="n-icon-btn shrink-0" title="Toggle Sidebar">
            <svg id="toggleIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" id="hamburgerIcon"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" id="closeIcon" class="hidden"/>
            </svg>
        </button>
    </div>

    <!-- ========== NAVIGATION (SCROLLABLE) ========== -->
    <nav class="flex-1 overflow-y-auto overflow-x-hidden n-scroll py-3 px-2" id="sidebarNav">

        <div class="mb-2 sidebar-group">
            <div class="section-title"><span class="section-label">Menu</span></div>
            <%- renderMenuItem(base_path, 'admin', 'dashboard', page, '<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>', 'Dashboard') %>
