        </button>
        <a href="<%= base_path %>/logout" class="nav-link logout-link" data-title="Logout">
            <div class="nav-icon"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg></div>
            <span class="sidebar-text">Logout</span>
        </a>
        <!-- Versi app (diisi scripts/deploy.sh) — untuk memastikan deploy benar masuk. -->
