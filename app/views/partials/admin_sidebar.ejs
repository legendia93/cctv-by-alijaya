</aside>

<!-- ========== MOBILE OVERLAY ========== -->
<div id="sidebarOverlay" onclick="closeMobileSidebar()" class="fixed inset-0 z-30 hidden opacity-0 transition-opacity duration-300" style="display:none;background:rgba(10,10,10,.5);"></div>

<style>
/* ===== LOGOMARK (dot-matrix 3x3) ===== */
.n-logomark { width: 34px; height: 34px; border-radius: 10px; background: var(--n-ink); display: grid; grid-template-columns: repeat(3,1fr); grid-template-rows: repeat(3,1fr); gap: 3px; padding: 7px; }
.n-logomark span { border-radius: 50%; background: var(--n-bg); }
.n-logomark span.dot-accent { background: var(--n-accent); }

/* ===== ICON BTN ===== */
.n-icon-btn { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--n-ink-soft); border: 1px solid var(--n-line); background: transparent; transition: background .15s ease, color .15s ease; cursor: pointer; }
.n-icon-btn:hover { background: var(--n-surface-2); color: var(--n-ink); }

/* ===== MOBILE SIDEBAR (Drawer from left) ===== */
@media (max-width: 767px) {
    #adminSidebar {
        position: fixed !important; top: 0 !important; left: -300px !important;
        height: 100vh !important; height: 100dvh !important; z-index: 40 !important;
        display: flex !important; transition: left 0.3s cubic-bezier(0.4,0,0.2,1) !important;
        width: 280px !important; min-width: 280px !important;
        box-shadow: 4px 0 30px rgba(0,0,0,0.18);
    }
    #adminSidebar.mobile-open { left: 0 !important; }
    #adminSidebar #sidebarNav { flex: 1 !important; overflow-y: auto !important; overflow-x: hidden !important; min-height: 0 !important; -webkit-overflow-scrolling: touch !important; }
    #sidebarOverlay.mobile-show { display: block !important; opacity: 1 !important; }
    .mobile-header-bar { display: flex !important; }
}
@media (min-width: 768px) {
    .mobile-header-bar { display: none !important; }
    #sidebarOverlay { display: none !important; }
}

/* ===== DESKTOP COLLAPSE ===== */
#adminSidebar.collapsed { width: 72px !important; min-width: 72px !important; }
#adminSidebar.collapsed .sidebar-text,
#adminSidebar.collapsed .nav-ext,
#adminSidebar.collapsed .section-title span { opacity: 0; width: 0; overflow: hidden; display: none; }
#adminSidebar.collapsed #logoText { opacity: 0; width: 0; display: none; }
#adminSidebar.collapsed .nav-link { justify-content: center; padding: 10px 0; margin: 0 4px 2px; }
#adminSidebar.collapsed .nav-link.active::before { display: none; }
#adminSidebar.collapsed .sidebar-group { margin-bottom: 4px; }
#adminSidebar.collapsed #hamburgerIcon { display: none; }
#adminSidebar.collapsed #closeIcon { display: block; }
#adminSidebar:not(.collapsed) #hamburgerIcon { display: block; }
#adminSidebar:not(.collapsed) #closeIcon { display: none; }

/* ===== SECTION LABEL (uppercase mono) ===== */
.section-title { padding: 6px 12px 2px; }
.sidebar-group { margin-bottom: 2px !important; }
.section-label { font-family: var(--font-mono); font-size: 9px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.22em; color: var(--n-ink-faint); user-select: none; }

/* ===== NAV LINK (flat, aktif = kotak/garis, bukan glow) ===== */
.nav-link {
    display: flex; align-items: center; gap: 12px;
    padding: 6px 12px; border-radius: 10px;
    transition: background .15s ease, color .15s ease;
    color: var(--n-ink-soft); text-decoration: none; white-space: nowrap;
    position: relative; margin-bottom: 0; border: 0; background: transparent; width: 100%; cursor: pointer;
    font-family: var(--font-sans);
}
.nav-link:hover { background: var(--n-surface-2); color: var(--n-ink); }
.nav-link.active { background: var(--n-ink); color: var(--n-bg); }
.nav-link.active .nav-icon svg { color: var(--n-bg) !important; }
.nav-link.active::before {
    content: ''; position: absolute; left: -2px; top: 50%; transform: translateY(-50%);
    width: 3px; height: 18px; border-radius: 2px; background: var(--n-accent);
}
.logout-link { color: var(--n-ink-soft); }
.logout-link:hover { background: var(--n-surface-2); color: var(--n-accent); }
.logout-link:hover .nav-icon svg { color: var(--n-accent) !important; }

.nav-icon { width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.nav-icon svg { width: 20px; height: 20px; }
.nav-ext { width: 13px; height: 13px; margin-left: auto; opacity: .5; flex-shrink: 0; }
.sidebar-text { font-size: 13px; font-weight: 500; transition: opacity 0.2s ease; white-space: nowrap; }
.n-new { font-family: var(--font-mono); font-size: 8px; letter-spacing: .1em; color: var(--n-accent); }

/* Theme icon swap */
.theme-ico-dark { display: none; }
[data-theme="dark"] .theme-ico-light { display: none; }
[data-theme="dark"] .theme-ico-dark { display: block; }

/* ===== TOOLTIP (collapsed) ===== */
#adminSidebar.collapsed .nav-link:hover::after {
    content: attr(data-title); position: absolute; left: 100%; margin-left: 12px;
    background: var(--n-ink); color: var(--n-bg); padding: 5px 12px; border-radius: 8px;
    font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .1em;
    white-space: nowrap; z-index: 999; box-shadow: var(--n-shadow);
    pointer-events: none; top: 50%; transform: translateY(-50%);
}
</style>

<script>
(function() {
    'use strict';
    const SIDEBAR_KEY = 'cctv_sidebar_collapsed';

    window.toggleSidebar = function() {
        const s = document.getElementById('adminSidebar');
        if (!s) return;
        const c = s.classList.toggle('collapsed');
        try { localStorage.setItem(SIDEBAR_KEY, c ? 'true' : 'false'); } catch(e) {}
    };
    window.openMobileSidebar = function() {
        const s = document.getElementById('adminSidebar');
        const o = document.getElementById('sidebarOverlay');
        if (!s) return;
        s.classList.add('mobile-open');
        if (o) { o.classList.add('mobile-show'); o.style.display = 'block'; }
        document.body.style.overflow = 'hidden';
    };
    window.closeMobileSidebar = function() {
        const s = document.getElementById('adminSidebar');
        const o = document.getElementById('sidebarOverlay');
        if (!s) return;
        s.classList.remove('mobile-open');
        if (o) { o.classList.remove('mobile-show'); o.style.display = 'none'; }
        document.body.style.overflow = '';
    };
    function loadState() {
        const s = document.getElementById('adminSidebar');
        if (!s) return;
        try { if (localStorage.getItem(SIDEBAR_KEY) === 'true') s.classList.add('collapsed'); } catch(e) {}
    }
    // Sinkron label tema
    function syncThemeLabel() {
        const el = document.getElementById('themeLabel');
        if (!el) return;
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        el.textContent = dark ? 'Mode Terang' : 'Mode Gelap';
    }
    document.addEventListener('themechange', syncThemeLabel);
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ loadState(); syncThemeLabel(); });
    else { loadState(); syncThemeLabel(); }
    setTimeout(loadState, 150);
})();
</script>

<!-- ============================================================ -->
<!-- MAIN CONTENT AREA START                                      -->
<!-- ============================================================ -->
