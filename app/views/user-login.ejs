<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#F4F4F4">
    <link rel="manifest" href="<%= base_path %>/manifest.json">
    <link rel="icon" href="<%= base_path %>/icon-192x192.png">
    <link rel="apple-touch-icon" href="<%= base_path %>/icon-192x192.png">
    <title>Login Pelanggan - CCTV</title>

    <!-- ===== Nothing OS theme (sumber kebenaran tunggal) ===== -->
    <%- include('partials/head_theme') %>

    <style>
        body { background: var(--n-bg); }
        /* .n-authbg (latar dot-grid) kini terpusat di nothing.css §13 */
        .n-logomark { width: 44px; height: 44px; border-radius: 12px; background: var(--n-ink); display: grid; grid-template-columns: repeat(3,1fr); grid-template-rows: repeat(3,1fr); gap: 4px; padding: 9px; }
        .n-logomark span { border-radius: 50%; background: var(--n-bg); }
        .n-logomark span.dot-accent { background: var(--n-accent); }
    </style>
</head>

<body class="flex items-center justify-center min-h-screen p-6">
    <div class="n-authbg"></div>

    <div class="w-full max-w-sm n-card p-9 n-fade-in relative" style="z-index:1;border-radius:var(--n-radius-lg);">
        <div class="text-center mb-9">
            <div class="n-logomark mx-auto mb-5">
                <span></span><span></span><span></span>
                <span></span><span class="dot-accent"></span><span></span>
                <span></span><span></span><span></span>
            </div>
            <div class="n-label mb-2">Akses Pelanggan</div>
            <h1 class="n-num" style="font-size:34px;">MASUK</h1>
        </div>

        <% if (locals.error) { %>
            <div class="n-card p-3 mb-6 text-sm text-center font-medium" style="border-color:var(--n-accent);color:var(--n-accent);">
                <%= error %>
            </div>
        <% } %>

        <form action="<%= base_path %>/user/login" method="POST" class="space-y-5">
            <div class="space-y-2">
                <label for="username" class="n-label block ml-1">Username</label>
                <input type="text" id="username" name="username" required class="n-input" placeholder="Masukkan username">
            </div>

            <div class="space-y-2">
                <label for="password" class="n-label block ml-1">Password</label>
                <input type="password" id="password" name="password" required class="n-input" placeholder="••••••••">
            </div>

            <button type="submit" class="n-btn n-btn-accent w-full" style="padding:14px;">
                Masuk ke Dashboard
            </button>

            <div class="text-center text-xs" style="color:var(--n-ink-soft);">
                Belum punya akun?
                <a href="<%= base_path %>/user/register" class="font-semibold ml-1 hover:opacity-70 transition-opacity" style="color:var(--n-accent);">Daftar Sekarang</a>
            </div>
        </form>

        <div class="mt-8 pt-6 flex justify-between items-center" style="border-top:1px solid var(--n-line);">
            <a href="<%= base_path %>/" class="n-label hover:opacity-70 transition-opacity">← Kembali</a>
            <a href="<%= base_path %>/login" class="n-label hover:opacity-70 transition-opacity">Admin Login</a>
        </div>
    </div>

    <script src="<%= base_path %>/js/password-toggle.js"></script>
    <script>
        (() => {
            const basePath = '<%= base_path %>' || '';
            if ('serviceWorker' in navigator) {
                window.addEventListener('load', () => {
                    navigator.serviceWorker.register(`${basePath}/sw.js`).catch(() => { });
                });
            }

            let deferredPrompt = null;
            const showBanner = () => {
                if (document.getElementById('pwa-install-banner')) return;
                const banner = document.createElement('div');
                banner.id = 'pwa-install-banner';
                banner.style.cssText = 'position:fixed;left:12px;right:12px;bottom:12px;z-index:9999;display:flex;gap:10px;align-items:center;justify-content:space-between;padding:14px 16px;background:var(--n-surface);border:1px solid var(--n-line);border-radius:18px;color:var(--n-ink);font:500 13px/1.3 "Space Grotesk", system-ui, sans-serif;box-shadow:var(--n-shadow);';
                banner.innerHTML = '<div style="display:flex;flex-direction:column;gap:2px"><div style="font-family:\'Space Mono\',monospace;font-weight:500;letter-spacing:.16em;text-transform:uppercase;font-size:10px;color:var(--n-ink-soft)">Install</div><div>Pasang aplikasi untuk akses lebih cepat.</div></div><div style="display:flex;gap:8px;flex-shrink:0"><button id="pwa-install-btn" style="padding:9px 14px;border-radius:999px;background:var(--n-accent);color:var(--n-accent-ink);border:0;font-family:\'Space Mono\',monospace;font-weight:500;text-transform:uppercase;letter-spacing:.1em;font-size:11px;cursor:pointer">Install</button><button id="pwa-close-btn" style="padding:9px 14px;border-radius:999px;background:transparent;color:var(--n-ink-soft);border:1px solid var(--n-line);font-family:\'Space Mono\',monospace;font-weight:500;text-transform:uppercase;letter-spacing:.1em;font-size:11px;cursor:pointer">Tutup</button></div>';
                document.body.appendChild(banner);
                document.getElementById('pwa-close-btn').onclick = () => banner.remove();
                document.getElementById('pwa-install-btn').onclick = async () => {
                    if (!deferredPrompt) return;
                    banner.remove();
                    deferredPrompt.prompt();
                    try { await deferredPrompt.userChoice; } catch { }
                    deferredPrompt = null;
                };
            };

            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault();
                deferredPrompt = e;
                showBanner();
            });

            window.addEventListener('appinstalled', () => {
                deferredPrompt = null;
                const b = document.getElementById('pwa-install-banner');
                if (b) b.remove();
            });
        })();
    </script>
</body>
</html>
