    // ===== Deteksi Stream (auto-probe path RTSP) =====
    async function detectStreams() {
        const text = document.getElementById('detectStreamText');
        const spin = document.getElementById('detectStreamSpin');
        const box = document.getElementById('detectResults');

        const rawUrl = document.getElementById('edit_url_rtsp').value.trim();
        if (!rawUrl) {
            showModal('Isi field URL RTSP dulu (IP saja juga boleh, mis. 10.10.111.8).', 'error');
            return;
        }

        text.innerText = 'Memindai path stream…';
        spin.classList.remove('hidden');
        box.classList.remove('hidden');
        box.innerHTML = '<div class="text-center p-3 bg-gray-950 rounded-xl text-gray-500 text-xs italic">Memindai path stream…</div>';

        try {
            const res = await fetch('<%= base_path %>/api/rtsp/detect-streams', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    input: rawUrl,
                    username: document.getElementById('detect_username').value,
                    password: document.getElementById('detect_password').value
                })
            });
            const data = await res.json();

            if (!data.reachable) {
                // Kamera cloud-only (host hidup tapi RTSP mati) → tampil sbg amber + ikon,
                // bukan merah "error", karena ini butuh aksi user (aktifkan RTSP), bukan bug.
                if (data.cloudOnly) {
                    box.innerHTML = `<div class="p-3 bg-amber-900/30 border border-amber-500/30 rounded-xl text-amber-200 text-xs flex gap-2">
                        <span class="shrink-0">☁️</span><span>${data.message}</span></div>`;
                } else {
                    box.innerHTML = `<div class="p-3 bg-rose-900/30 border border-rose-500/30 rounded-xl text-rose-300 text-xs">${data.message || 'Kamera tidak dapat dijangkau.'}</div>`;
                }
                return;
            }
            if (!data.results || data.results.length === 0) {
                box.innerHTML = `<div class="p-3 bg-amber-900/30 border border-amber-500/30 rounded-xl text-amber-300 text-xs">${data.message || 'Tidak ada path stream terdeteksi.'}</div>`;
                return;
            }

            box.innerHTML = '';
            if (data.port) {
                const head = document.createElement('div');
                head.className = 'text-[10px] text-gray-500 uppercase tracking-widest font-black mb-1';
                head.innerText = `Port terdeteksi: ${data.port} · ${data.results.length} stream ditemukan`;
                box.appendChild(head);
            }
            data.results.forEach((r, idx) => {
                const isRec = idx === 0; // sudah terurut resolusi tertinggi dulu
                const notWidescreen = r.ratio !== '16:9';
                const div = document.createElement('div');
                div.className = 'p-3 bg-gray-950 rounded-xl border ' + (isRec ? 'border-emerald-500/50' : 'border-gray-700') + ' flex items-center justify-between gap-3';
                div.innerHTML = `
                    <div class="min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="text-white text-sm font-bold">${r.width}×${r.height}</span>
                            <span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full bg-gray-800 text-gray-400 border border-gray-700">${r.codec}</span>
                            <span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full bg-blue-900/40 text-blue-300 border border-blue-500/20">${r.ratio}</span>
                            <span class="text-[9px] font-black uppercase tracking-widest text-gray-500">${r.label}</span>
                            ${isRec ? '<span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full bg-emerald-900/40 text-emerald-300 border border-emerald-500/30">Rekomendasi</span>' : ''}
                        </div>
                        <div class="text-[10px] text-gray-500 font-mono truncate mt-1" title="${r.url}">${r.url}</div>
                        ${notWidescreen ? '<div class="text-[10px] text-amber-400/80 mt-1">⚠ Rasio bukan 16:9 — kemungkinan sub-stream.</div>' : ''}
                    </div>
                    <button type="button" class="use-stream-btn bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] font-bold px-4 py-2 rounded-lg transition shrink-0" data-url="${r.url}">Pakai</button>
                `;
                box.appendChild(div);
            });

            box.querySelectorAll('.use-stream-btn').forEach(btn => {
                btn.onclick = () => {
                    document.getElementById('edit_url_rtsp').value = btn.dataset.url;
                    box.classList.add('hidden');
                    box.innerHTML = '';
                    showModal('URL RTSP terisi dari hasil deteksi.');
                };
            });
        } catch (e) {
            box.innerHTML = '<div class="p-3 bg-rose-900/30 border border-rose-500/30 rounded-xl text-rose-300 text-xs">Gagal menghubungi server deteksi.</div>';
        } finally {
            text.innerText = '🔍 Deteksi Stream';
            spin.classList.add('hidden');
        }
    }

