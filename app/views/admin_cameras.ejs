    async function loadBulkBrands() {
        try {
            const res = await fetch('<%= base_path %>/api/dvr/brand-templates');
            const data = await res.json();
            BULK_BRANDS = data.brands || {};
            const sel = document.getElementById('bulkBrand');
            sel.innerHTML = '<option value="">Pilih merek…</option>';
            // Hanya merek dengan token {channel} yang relevan untuk bulk.
            Object.keys(BULK_BRANDS).forEach(key => {
                const info = BULK_BRANDS[key];
                if (!info.template.includes('{channel}')) return;
                const opt = document.createElement('option');
                opt.value = key;
                opt.textContent = info.name;
                sel.appendChild(opt);
            });
        } catch (e) {
            bulkBrandsLoaded = false; // izinkan retry saat dibuka lagi
            document.getElementById('bulkBrand').innerHTML = '<option value="">Gagal memuat merek</option>';
        }
    }

    function bulkCollect() {
        return {
            brand: document.getElementById('bulkBrand').value,
            ip: document.getElementById('bulkIp').value.trim(),
            port: document.getElementById('bulkPort').value.trim(),
            username: document.getElementById('bulkUsername').value,
            password: document.getElementById('bulkPassword').value,
            stream: document.getElementById('bulkStream').value,
            channelStart: document.getElementById('bulkChannelStart').value,
            channelEnd: document.getElementById('bulkChannelEnd').value,
            level: document.getElementById('bulkLevel').value,
            namePrefix: document.getElementById('bulkNamePrefix').value.trim(),
            lokasi: document.getElementById('bulkLokasi').value.trim(),
            enable_recording: document.getElementById('bulkEnableRecording').checked ? '1' : '0'
        };
    }

    // Bangun URL preview di client (meniru template server, TANPA kredensial nyata di layar).
    function bulkBuildPreviewUrl(brand, ch, data) {
        const info = BULK_BRANDS[brand];
        if (!info) return null;
        const streamType = data.stream === 'sub' ? 'sub' : 'main';
        const params = {
            username: encodeURIComponent(data.username || 'user'),
            password: '••••',
            ip: data.ip || '192.168.1.100',
            port: data.port || info.defaults.port,
            channel: ch,
            stream: streamType === 'main' ? 'main' : 'sub',
            subtype: streamType === 'main' ? 0 : 1
        };
        Object.keys(info.defaults).forEach(k => {
            if (params[k] === undefined || params[k] === null || params[k] === '') params[k] = info.defaults[k];
        });
        let url = info.template;
        Object.keys(params).forEach(k => { url = url.replace(new RegExp(`\\{${k}\\}`, 'g'), params[k]); });
        return url;
    }

    function bulkValidate(data) {
        if (!data.brand) return 'Pilih merek dulu.';
        if (!data.ip) return 'IP address wajib diisi.';
        if (!data.username || !data.password) return 'Username & password wajib diisi.';
        const s = parseInt(data.channelStart, 10), e = parseInt(data.channelEnd, 10);
        if (!Number.isInteger(s) || !Number.isInteger(e) || s < 1 || e < s) return 'Rentang channel tidak valid.';
        if (e - s + 1 > 64) return 'Maksimal 64 channel.';
        return null;
    }

    function bulkSetSubmitEnabled(on) {
        const btn = document.getElementById('bulkSubmitBtn');
        btn.disabled = !on;
        btn.style.opacity = on ? '1' : '.5';
        btn.style.cursor = on ? 'pointer' : 'not-allowed';
    }

    document.getElementById('bulkPreviewBtn').onclick = () => {
        const data = bulkCollect();
        const err = bulkValidate(data);
        const box = document.getElementById('bulkPreview');
        box.classList.remove('hidden');
        if (err) {
            box.innerHTML = `<div class="p-3 rounded-xl text-xs" style="color:var(--n-accent);border:1px solid var(--n-accent);">${err}</div>`;
            bulkSetSubmitEnabled(false);
            return;
        }
        const prefix = data.namePrefix || (BULK_BRANDS[data.brand] ? BULK_BRANDS[data.brand].name : 'CAM');
        const s = parseInt(data.channelStart, 10), e = parseInt(data.channelEnd, 10);
        let html = `<div class="n-label mb-1">${e - s + 1} kamera akan dibuat</div>`;
        for (let ch = s; ch <= e; ch++) {
            const url = bulkBuildPreviewUrl(data.brand, ch, data);
            html += `<div class="p-2 rounded-lg flex items-center gap-3" style="background:var(--n-bg);border:1px solid var(--n-line);">
                <span class="text-xs font-bold shrink-0" style="color:var(--n-ink);">${prefix} CH${ch}</span>
                <code class="text-[10px] font-mono truncate" style="color:var(--n-ink-soft);">${url}</code>
            </div>`;
        }
        box.innerHTML = html;
        bulkSetSubmitEnabled(true);
    };

    document.getElementById('bulkSubmitBtn').onclick = async () => {
        const data = bulkCollect();
        const err = bulkValidate(data);
        if (err) { showModal(err, 'error'); return; }
        const btn = document.getElementById('bulkSubmitBtn');
        const resultBox = document.getElementById('bulkResult');
        bulkSetSubmitEnabled(false);
        btn.textContent = 'Menambahkan…';
        resultBox.classList.add('hidden');
        try {
            const res = await fetch('<%= base_path %>/api/dvr/bulk-add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const out = await res.json();
            resultBox.classList.remove('hidden');
            if (!out.success) {
                resultBox.innerHTML = `<div class="p-3 rounded-xl text-xs" style="color:var(--n-accent);border:1px solid var(--n-accent);">${out.message || 'Gagal.'}</div>`;
            } else {
                let html = `<div class="p-3 rounded-xl text-sm font-bold" style="color:var(--n-ink);border:1px solid var(--n-line);">${out.addedCount} kamera ditambahkan${out.failedCount ? `, ${out.failedCount} gagal` : ''}.</div>`;
                if (out.failedCount) {
                    html += '<div class="mt-2 space-y-1">' + out.failed.map(f =>
                        `<div class="text-[10px]" style="color:var(--n-accent);">CH${f.channel}: ${f.reason}</div>`).join('') + '</div>';
                }
                resultBox.innerHTML = html;
                showModal(`${out.addedCount} kamera berhasil ditambahkan`);
                // Muat ulang agar kamera baru langsung tampil di tabel.
                setTimeout(() => window.location.reload(), 1500);
            }
        } catch (e) {
            resultBox.classList.remove('hidden');
            resultBox.innerHTML = `<div class="p-3 rounded-xl text-xs" style="color:var(--n-accent);border:1px solid var(--n-accent);">Kesalahan koneksi.</div>`;
        } finally {
            btn.textContent = 'Tambah Semua';
            bulkSetSubmitEnabled(true);
        }
    };

    /* ================= PREVIEW LIVE (klik badge status) ================= */
    const previewHlsBase = '<%= typeof hlsBaseUrl !== "undefined" ? hlsBaseUrl : "" %>';
    let previewHls = null;

    // Ubah URL YouTube/embed jadi bentuk yang bisa dipasang di iframe.
    function toEmbedSrc(url) {
        if (!url) return '';
        const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|live\/))([\w-]{11})/);
        if (yt) return 'https://www.youtube.com/embed/' + yt[1] + '?autoplay=1&mute=1';
        return url;
    }

    function openPreview(id) {
        const pill = document.getElementById('admin-status-' + id);
        const nama = pill ? pill.dataset.nama : ('Kamera ' + id);
        const type = pill ? pill.dataset.camera_type : 'rtsp';
        const embedUrl = pill ? pill.dataset.embed_url : '';

        const backdrop = document.getElementById('previewBackdrop');
        const video = document.getElementById('previewVideo');
        const frame = document.getElementById('previewFrame');
        const loading = document.getElementById('previewLoading');
        const errBox = document.getElementById('previewError');

        document.getElementById('previewTitle').textContent = nama;
        document.getElementById('previewSub').textContent = 'ID ' + id + ' • ' + (type === 'embed' ? 'Embed' : 'RTSP / HLS');
        errBox.classList.add('hidden'); errBox.classList.remove('flex');
        backdrop.classList.remove('hidden'); backdrop.classList.add('flex');

        if (type === 'embed') {
            // Embed (YouTube dll) tidak lewat MediaMTX — pakai iframe.
            video.classList.add('hidden');
            frame.classList.remove('hidden');
            loading.classList.add('hidden');
            frame.src = toEmbedSrc(embedUrl);
            return;
        }

        frame.classList.add('hidden'); frame.src = '';
        video.classList.remove('hidden');
        loading.classList.remove('hidden');

        const primaryUrl = previewHlsBase + '/cam_' + id + '/index.m3u8';
        const fallbackUrl = previewHlsBase + '/cam_' + id + '_input/index.m3u8';
        const done = () => loading.classList.add('hidden');
        const fail = () => {
            loading.classList.add('hidden');
            errBox.classList.remove('hidden'); errBox.classList.add('flex');
        };

        video.addEventListener('playing', done, { once: true });
        video.addEventListener('canplay', done, { once: true });

        if (typeof Hls !== 'undefined' && Hls.isSupported()) {
            const hls = new Hls({ manifestLoadingMaxRetry: 2, manifestLoadingRetryDelay: 1000 });
            hls.loadSource(primaryUrl);
            hls.attachMedia(video);
            hls.on(Hls.Events.MANIFEST_PARSED, () => video.play().catch(() => {}));
            hls.on(Hls.Events.ERROR, (ev, data) => {
                if (!data.fatal) return;
                hls.destroy();
                // Fallback ke path _input (stream mentah dari kamera).
                const fb = new Hls({ manifestLoadingMaxRetry: 3, manifestLoadingRetryDelay: 1000 });
                fb.loadSource(fallbackUrl);
                fb.attachMedia(video);
                fb.on(Hls.Events.MANIFEST_PARSED, () => video.play().catch(() => {}));
                fb.on(Hls.Events.ERROR, (e2, d2) => { if (d2.fatal) { fb.destroy(); previewHls = null; fail(); } });
                previewHls = fb;
            });
            previewHls = hls;
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
            video.src = primaryUrl;
            video.addEventListener('error', fail, { once: true });
            video.play().catch(() => {});
        } else {
            fail();
        }
    }

    function closePreview() {
        const backdrop = document.getElementById('previewBackdrop');
        const video = document.getElementById('previewVideo');
        const frame = document.getElementById('previewFrame');
        if (previewHls) { previewHls.destroy(); previewHls = null; }
        video.pause(); video.removeAttribute('src'); video.load();
        frame.src = '';
        backdrop.classList.add('hidden'); backdrop.classList.remove('flex');
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !document.getElementById('previewBackdrop').classList.contains('hidden')) closePreview();
    });

</script>

