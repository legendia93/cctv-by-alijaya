    // ========== BULK ADD (1 DVR/NVR, banyak channel) ==========
    // Dipindah dari halaman DVR/APK → di sini, sebagai modal, agar semua jalur
    // "menambah kamera" (satuan & massal) berada di satu tempat.
    let BULK_BRANDS = {};
    let bulkBrandsLoaded = false;

    function openBulkForm() {
        const bd = document.getElementById('bulkModalBackdrop');
        bd.classList.remove('hidden');
        bd.classList.add('flex');
        document.body.style.overflow = 'hidden';
