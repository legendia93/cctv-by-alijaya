<%- include('partials/admin_header', { title: 'Permission Manager' }) %>
<%- include('partials/admin_sidebar', { page: 'permissions' }) %>

<div class="n-card p-6 mb-8" style="background:transparent;">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                Permission Manager - Level Akses Premium
            </h2>
            <p class="text-[10px] text-gray-400 mt-1">Atur hak akses menu & fitur untuk setiap level pengguna secara real-time</p>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="resetAllPermissions()" class="text-[10px] bg-rose-700 hover:bg-rose-600 text-white px-3 py-1.5 rounded-lg transition font-bold flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Reset All
            </button>
            <button onclick="saveAllPermissions()" class="text-[10px] bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-1.5 rounded-lg transition font-bold flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Simpan Semua
            </button>
        </div>
    </div>

    <!-- Permission Editor: satu tabel, kolom = level, baris = fitur -->
    <div id="permissionEditor">
        <div class="text-center text-gray-500 text-sm py-8">Loading permissions...</div>
    </div>
</div>

<style>
    /* Toggle pill: OFF merah, ON hijau — jelas tanpa harus baca posisi knob. */
    .perm-sw {
        position: relative; display: inline-flex; align-items: center;
        width: 42px; height: 22px; border-radius: 999px; cursor: pointer;
        background: rgba(244, 63, 94, 0.18); border: 1px solid rgba(244, 63, 94, 0.45);
        transition: background .15s ease, border-color .15s ease;
    }
    .perm-sw::after {
        content: ''; position: absolute; left: 2px; top: 50%; transform: translateY(-50%);
        width: 16px; height: 16px; border-radius: 50%;
        background: #f43f5e; transition: transform .18s ease, background .15s ease;
    }
    .perm-sw.on { background: rgba(16, 185, 129, 0.18); border-color: rgba(16, 185, 129, 0.5); }
    .perm-sw.on::after { transform: translateY(-50%) translateX(20px); background: #10b981; }
    .perm-sw.locked { opacity: .35; cursor: not-allowed; }

    /* Tabel transparan: hanya garis pemisah, tanpa bidang warna.
       Sticky column dimatikan agar tak butuh background solid. */
    .perm-table td, .perm-table th { background: transparent; }
    .perm-table tbody tr.perm-item:hover td { background: rgba(255, 255, 255, 0.035); }
    .perm-item td { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }

    /* Baris judul section: bidang sangat tipis supaya terbaca sebagai
       pemisah kelompok, tanpa jadi blok abu solid. */
    .perm-group-row { cursor: pointer; user-select: none; }
    .perm-group-row td {
        background: rgba(255, 255, 255, 0.025);
        border-top: 1px solid rgba(255, 255, 255, 0.07);
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
    .perm-table tbody tr.perm-group-row:hover td { background: rgba(255, 255, 255, 0.055); }
</style>

<script>
let permissionsData = {};

// Level yang tampil sebagai kolom tabel (urut dari akses paling rendah).
const LEVELS = ['umum', 'member', 'admin'];
const levelNames = { admin: 'Administrator', member: 'Member', umum: 'Umum (Gratis)' };
const levelBadge = {
    admin: 'bg-emerald-900/40 text-emerald-400 border-emerald-500/30',
    member: 'bg-blue-900/40 text-blue-400 border-blue-500/30',
    umum: 'bg-gray-700 text-gray-300 border-gray-600/50'
};

const menuGroups = {
    'Streaming': ['camera_preview','camera_playback','camera_embed','camera_map'],
    'Data & Informasi': ['recordings','incident_reports','incident_create','weather_view','weather_marine'],
    'Akun Pengguna': ['user_account','user_billing','push_notifications'],
    'Admin Panel': ['admin_dashboard','admin_cameras','admin_customers','admin_recordings','admin_storage','admin_streaming','admin_billing','admin_finance','admin_reports','admin_alerts','admin_settings','admin_ptz','admin_whatsapp','admin_activity','system_update']
};

const menuLabels = {
    camera_preview: 'Preview Kamera', camera_playback: 'Playback Rekaman',
    camera_embed: 'Embed Kamera', camera_map: 'Peta Kamera',
    recordings: 'Arsip Rekaman', incident_reports: 'Laporan Kejadian',
    incident_create: 'Buat Laporan', weather_view: 'Info Cuaca',
    weather_marine: 'Cuaca Marine', user_account: 'Akun Saya',
    user_billing: 'Billing & Paket', push_notifications: 'Notifikasi Push',
    admin_dashboard: 'Dashboard', admin_cameras: 'Manajemen Kamera',
    admin_customers: 'Manajemen Pelanggan', admin_recordings: 'Jadwal Rekaman',
    admin_storage: 'Penyimpanan Rekaman', admin_streaming: 'Streaming YouTube',
    admin_billing: 'Paket Billing', admin_finance: 'Keuangan',
    admin_reports: 'Laporan', admin_alerts: 'Sistem Alert',
    admin_settings: 'Pengaturan', admin_ptz: 'PTZ Control',
    admin_whatsapp: 'WhatsApp Bot', admin_activity: 'Log Aktivitas', system_update: 'Update Sistem'
};

const menuDescs = {
    camera_preview: 'Melihat live stream kamera', camera_playback: 'Memutar ulang rekaman video',
    camera_embed: 'Mengakses kamera embed/YouTube', camera_map: 'Melihat peta lokasi kamera',
    recordings: 'Download & hapus file rekaman', incident_reports: 'Melihat laporan publik',
    incident_create: 'Membuat laporan kejadian baru', weather_view: 'Informasi cuaca & forecast',
    weather_marine: 'Peringatan cuaca laut', user_account: 'Profil pengguna',
    user_billing: 'Pembelian paket & histori', push_notifications: 'Notifikasi browser/telegram',
    admin_dashboard: 'Ringkasan sistem', admin_cameras: 'Tambah/edit/hapus kamera',
    admin_customers: 'Kelola user, level, permission', admin_recordings: 'Atur jadwal & kualitas rekaman',
    admin_storage: 'Atur penyimpanan internal/eksternal', admin_streaming: 'Konfigurasi RTMP/YouTube',
    admin_billing: 'Kelola paket harga', admin_finance: 'Transaksi & pendapatan',
    admin_reports: 'Verifikasi laporan insiden', admin_alerts: 'Atur notifikasi & alert',
    admin_settings: 'Pengaturan web & bot', admin_ptz: 'Kontrol kamera PTZ',
    admin_whatsapp: 'Status koneksi WA', admin_activity: 'Audit trail & log aktivitas sistem',
    system_update: 'Update aplikasi via git'
};

// Menu admin_* terkunci untuk level non-admin (aturan lama dipertahankan).
function isLocked(level, menuId) {
    return level !== 'admin' && (menuId.startsWith('admin_') || menuId === 'system_update');
}

function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// Nama grup -> id yang aman dipakai di class/id HTML.
function slug(s) {
    return String(s).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

// Semua section default tertutup; nilai true = terbuka.
let collapseState = {};

function toggleGroupCollapse(group) {
    const gkey = slug(group);
    const open = !(collapseState[group] === true);
    collapseState[group] = open;

    document.querySelectorAll('tr.grp-' + gkey).forEach(function (tr) {
        tr.style.display = open ? '' : 'none';
    });
    const arrow = document.getElementById('arrow-' + gkey);
    if (arrow) arrow.style.transform = open ? 'rotate(90deg)' : '';
}

function setAllGroups(open) {
    Object.keys(menuGroups).forEach(function (g) {
        if ((collapseState[g] === true) !== open) toggleGroupCollapse(g);
    });
}

async function loadPermissions() {
    try {
        const res = await fetch('<%= base_path %>/api/permissions/all');
        const data = await res.json();
        if (data.success) {
            permissionsData = data.permissions;
            renderPermissions();
        }
    } catch (e) {
        console.error('[Permissions] Load error:', e);
    }
}

function renderPermissions() {
    if (!permissionsData || !Object.keys(permissionsData).length) {
        document.getElementById('permissionEditor').innerHTML =
            '<div class="text-center text-gray-500 py-8">No permissions data</div>';
        return;
    }

    let html = '';

    // Baris atas: ringkasan jumlah aktif + aksi cepat ON/OFF per level,
    // plus expand/collapse semua section.
    html += '<div class="flex flex-wrap items-center gap-x-2 gap-y-2 mb-4 pb-4 border-b border-gray-700">';
    LEVELS.forEach(function (lv) {
        const p = permissionsData[lv] || {};
        const total = Object.keys(p).length;
        const on = Object.keys(p).filter(function (k) { return p[k]; }).length;
        html += '<span class="inline-flex items-center gap-1.5 mr-3">';
        html += '<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest border ' + levelBadge[lv] + '">' + lv + '</span>';
        html += '<span class="text-[10px] text-gray-300 tabular-nums" id="count-' + lv + '">' + on + ' / ' + total + '</span>';
        html += '<button onclick="toggleAll(\'' + lv + '\',true)" class="text-[8px] bg-emerald-700/40 hover:bg-emerald-600 text-emerald-300 px-1.5 py-0.5 rounded font-bold transition" title="Aktifkan semua untuk level ' + lv + '">ON</button>';
        html += '<button onclick="toggleAll(\'' + lv + '\',false)" class="text-[8px] bg-rose-700/40 hover:bg-rose-600 text-rose-300 px-1.5 py-0.5 rounded font-bold transition" title="Nonaktifkan semua untuk level ' + lv + '">OFF</button>';
        html += '</span>';
    });
    html += '<span class="ml-auto inline-flex items-center gap-1">';
    html += '<button onclick="setAllGroups(true)" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-white px-3 py-1.5 rounded-lg font-bold transition">Buka Semua</button>';
    html += '<button onclick="setAllGroups(false)" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-white px-3 py-1.5 rounded-lg font-bold transition">Tutup Semua</button>';
    html += '</span>';
    html += '</div>';

    html += '<div class="overflow-x-auto"><table class="perm-table w-full text-xs min-w-[560px]">';

    // Header: kolom fitur + satu kolom per level.
    html += '<thead><tr class="border-b border-gray-700">';
    html += '<th class="px-3 py-2 text-left text-[9px] uppercase tracking-widest font-black text-gray-300">Fitur</th>';
    LEVELS.forEach(function (lv) {
        html += '<th class="px-3 py-2 text-center">';
        html += '<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest border ' + levelBadge[lv] + '" title="' + esc(levelNames[lv]) + '">' + lv + '</span>';
        html += '</th>';
    });
    html += '</tr></thead><tbody>';

    // Baris per grup: 1 baris judul section (bisa collapse), lalu baris-baris fitur.
    Object.keys(menuGroups).forEach(function (group) {
        const menuIds = menuGroups[group];
        const gkey = slug(group);
        const open = collapseState[group] === true;

        html += '<tr class="perm-group-row" onclick="toggleGroupCollapse(\'' + esc(group) + '\')" title="Klik untuk buka/tutup section">';
        html += '<td class="px-3 py-2">';
        html += '<span class="inline-flex items-center gap-2">';
        html += '<svg id="arrow-' + gkey + '" class="w-3 h-3 text-gray-300 transition-transform duration-200" style="' + (open ? 'transform:rotate(90deg)' : '') + '" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>';
        html += '<span class="text-[9px] font-black text-gray-100 uppercase tracking-widest">' + esc(group) + '</span>';
        html += '<span class="text-[9px] text-gray-400">(' + menuIds.length + ')</span>';
        html += '</span></td>';
        LEVELS.forEach(function (lv) {
            // Ringkasan "aktif/total" + tombol aktifkan/nonaktifkan seluruh grup.
            const p = permissionsData[lv] || {};
            const onCount = menuIds.filter(function (id) { return p[id] === true; }).length;
            html += '<td class="px-3 py-2 text-center">';
            html += '<div class="inline-flex items-center gap-1.5">';
            html += '<span class="text-[9px] text-gray-300 tabular-nums" id="gcount-' + lv + '-' + gkey + '">' + onCount + '/' + menuIds.length + '</span>';
            html += '<button onclick="event.stopPropagation(); toggleGroup(\'' + lv + '\',\'' + esc(group) + '\',true)" class="text-[8px] bg-emerald-700/40 hover:bg-emerald-600 text-emerald-300 px-1.5 py-0.5 rounded font-bold transition" title="Aktifkan semua di grup ini">ON</button>';
            html += '<button onclick="event.stopPropagation(); toggleGroup(\'' + lv + '\',\'' + esc(group) + '\',false)" class="text-[8px] bg-rose-700/40 hover:bg-rose-600 text-rose-300 px-1.5 py-0.5 rounded font-bold transition" title="Nonaktifkan semua di grup ini">OFF</button>';
            html += '</div></td>';
        });
        html += '</tr>';

        menuIds.forEach(function (id, idx) {
            html += '<tr class="perm-item grp-' + gkey + '"' + (open ? '' : ' style="display:none"') + '>';
            html += '<td class="px-3 py-2">';
            html += '<div class="text-gray-50 font-medium">' + esc(menuLabels[id] || id) + '</div>';
            html += '<div class="text-[9px] text-gray-400">' + esc(menuDescs[id] || '') + '</div>';
            html += '</td>';

            LEVELS.forEach(function (lv) {
                const perms = permissionsData[lv] || {};
                const on = perms[id] === true;
                const locked = isLocked(lv, id);
                html += '<td class="px-3 py-2 text-center">';
                if (locked) {
                    html += '<span class="perm-sw locked" title="Menu admin tidak tersedia untuk level ' + lv + '"></span>';
                } else {
                    html += '<span class="perm-sw' + (on ? ' on' : '') + '" id="sw-' + lv + '-' + id + '"' +
                            ' onclick="togglePermission(\'' + lv + '\',\'' + id + '\')"' +
                            ' title="' + (on ? 'Aktif — klik untuk mematikan' : 'Nonaktif — klik untuk mengaktifkan') + '"></span>';
                }
                html += '</td>';
            });
            html += '</tr>';
        });
    });

    html += '</tbody></table></div>';

    // Legenda.
    html += '<div class="flex flex-wrap items-center gap-4 mt-4 pt-3 border-t border-gray-700 text-[10px] text-gray-300">';
    html += '<span class="flex items-center gap-1.5"><span class="perm-sw on" style="pointer-events:none;transform:scale(.8)"></span> Aktif</span>';
    html += '<span class="flex items-center gap-1.5"><span class="perm-sw" style="pointer-events:none;transform:scale(.8)"></span> Nonaktif</span>';
    html += '<span class="flex items-center gap-1.5"><span class="perm-sw locked" style="pointer-events:none;transform:scale(.8)"></span> Terkunci (khusus admin)</span>';
    html += '</div>';

    document.getElementById('permissionEditor').innerHTML = html;
}

// Update angka aktif (header level + tiap section) tanpa render ulang tabel.
function updateCount(level) {
    const p = permissionsData[level] || {};
    const el = document.getElementById('count-' + level);
    if (el) {
        const total = Object.keys(p).length;
        const on = Object.keys(p).filter(function (k) { return p[k]; }).length;
        el.innerText = on + ' / ' + total;
    }
    Object.keys(menuGroups).forEach(function (g) {
        const ids = menuGroups[g];
        const gc = document.getElementById('gcount-' + level + '-' + slug(g));
        if (!gc) return;
        gc.innerText = ids.filter(function (id) { return p[id] === true; }).length + '/' + ids.length;
    });
}

function togglePermission(level, menuId) {
    if (isLocked(level, menuId)) return;
    if (!permissionsData[level]) permissionsData[level] = {};
    const next = !(permissionsData[level][menuId] === true);
    permissionsData[level][menuId] = next;

    const sw = document.getElementById('sw-' + level + '-' + menuId);
    if (sw) {
        sw.classList.toggle('on', next);
        sw.title = next ? 'Aktif — klik untuk mematikan' : 'Nonaktif — klik untuk mengaktifkan';
    }
    updateCount(level);
}

function toggleGroup(level, group, value) {
    const menuIds = menuGroups[group];
    if (!menuIds || !permissionsData[level]) return;
    menuIds.forEach(function (id) {
        if (isLocked(level, id)) return;
        permissionsData[level][id] = value;
        const sw = document.getElementById('sw-' + level + '-' + id);
        if (sw) sw.classList.toggle('on', value);
    });
    updateCount(level);
}

function toggleAll(level, value) {
    const perms = permissionsData[level];
    if (!perms) return;
    Object.keys(perms).forEach(function (id) {
        if (isLocked(level, id)) return;
        perms[id] = value;
        const sw = document.getElementById('sw-' + level + '-' + id);
        if (sw) sw.classList.toggle('on', value);
    });
    updateCount(level);
}

// Save all permissions
async function saveAllPermissions() {
    const btn = document.querySelector('button[onclick*="saveAllPermissions"]');
    if (btn) { btn.disabled = true; btn.innerText = 'Menyimpan...'; }

    try {
        const res = await fetch('<%= base_path %>/api/permissions/save-all', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ permissions: permissionsData })
        });
        const data = await res.json();
        if (data.success) {
            showModal('✅ Semua permission berhasil disimpan!\n\n' +
                Object.keys(permissionsData).length + ' level diperbarui.\n' +
                'Perubahan berlaku segera.');
        } else {
            showModal('❌ Gagal: ' + (data.error || JSON.stringify(data)), 'error');
        }
    } catch (e) {
        showModal('❌ Gagal: ' + e.message, 'error');
    }

    if (btn) { btn.disabled = false; btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Simpan Semua'; }
}

// Reset all to defaults
async function resetAllPermissions() {
    showModal('⚠️ Reset semua permission ke default?\n\nSemua custom permission akan hilang dan kembali ke pengaturan bawaan.', 'confirm', async () => {
        try {
            const res = await fetch('<%= base_path %>/api/permissions/reset', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                showModal('✅ Permission direset ke default.');
                loadPermissions();
            }
        } catch (e) {
            showModal('❌ Gagal: ' + e.message, 'error');
        }
    });
}

document.addEventListener('DOMContentLoaded', loadPermissions);
</script>

<%- include('partials/admin_footer') %>
