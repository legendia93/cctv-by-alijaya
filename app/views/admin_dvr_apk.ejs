<%- include('partials/admin_header', { title: 'Tambah Kamera DVR/APK' }) %>
<%- include('partials/admin_sidebar', { page: 'dvr_apk' }) %>

<style>
    .brand-card {
        transition: all 0.15s ease;
        cursor: pointer;
    }
    .brand-card:hover { border-color: var(--n-ink) !important; }
    /* Compact: kartu merek di panel kiri yg sempit */
    #brandGrid .brand-card { padding: 10px 8px !important; }
    /* Kotak ikon merek → monokrom (buang gradient warna) & kecilkan */
    #brandGrid .brand-card > div:first-child {
        width: 34px !important; height: 34px !important;
        margin-bottom: 6px !important;
        background: var(--n-surface-2) !important;
        border: 1px solid var(--n-line);
        border-radius: 10px !important;
        box-shadow: none !important;
    }
    #brandGrid .brand-card > div:first-child svg { width: 18px !important; height: 18px !important; color: var(--n-ink) !important; }
    #brandGrid .brand-card .font-bold { font-size: 12px !important; }
    #brandGrid .brand-card .text-\[10px\] { font-size: 9px !important; margin-top: 2px !important; }
    #brandGrid .brand-card .device-tag,
    #brandGrid .brand-card .protocol-badge { margin-top: 5px !important; color: var(--n-ink-soft) !important; }
    /* Ikon EZVIZ pakai .n-brandbox (ink) — override agar seragam */
    #brandGrid .brand-card > div.n-brandbox { background: var(--n-surface-2) !important; }
    #brandGrid .brand-card > div.n-brandbox svg { color: var(--n-ink) !important; }
    .n-brandbox { background: var(--n-ink); box-shadow: var(--n-shadow); }
    .n-brandbox svg, .n-brandbox .text-white, .n-brandbox span { color: var(--n-bg) !important; }
    .brand-card.selected {
        border-color: var(--n-ink) !important;
        background: var(--n-surface-2) !important;
        box-shadow: var(--n-shadow);
    }
    .device-tag {
        background: var(--n-surface-2);
        border: 1px solid var(--n-line);
    }
    .protocol-badge {
        background: var(--n-surface-2);
        border: 1px solid var(--n-line);
    }
    .step-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .step-number {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 13px;
        transition: all 0.3s;
    }
    .step-number.active {
        background: var(--n-ink);
        color: var(--n-bg);
    }
    .step-number.completed {
        background: var(--n-ink);
        color: var(--n-bg);
    }
    .step-number.inactive {
        background: #2d3544;
        color: #6b7280;
    }
    @keyframes pulse-green {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
    .testing-active {
        animation: pulse-green 1s ease-in-out infinite;
    }

    /* ===== Compact + on-theme untuk panel Konfigurasi & baris Info =====
       #info-row ikut di-scope karena panel info dipindah KELUAR #step2-content
       (jadi baris full-width di atas kedua panel) — tanpa ini ia kehilangan token. */
    #step2-content .bg-gray-800 {
        background: var(--n-surface) !important;
        border-color: var(--n-line) !important;
        border-radius: var(--n-radius) !important;
        box-shadow: var(--n-shadow) !important;
        padding: 16px !important;
        margin-bottom: 16px !important;
    }
    #info-row .bg-gray-800 {
        background: var(--n-surface) !important;
        border-color: var(--n-line) !important;
        border-radius: var(--n-radius) !important;
        box-shadow: var(--n-shadow) !important;
    }
    #info-row h3 { font-size: 13px !important; margin-bottom: 10px !important; }
    #info-row .text-emerald-400,
    #info-row .text-blue-400,
    #info-row .text-purple-400,
    #info-row .text-amber-400 { color: var(--n-ink) !important; }
    #info-row code { color: var(--n-accent) !important; }
    #info-row .bg-blue-500,
    #info-row .bg-purple-500,
    #info-row .bg-cyan-500,
    #info-row .bg-emerald-500 { background: var(--n-ink) !important; }
    /* input & select lebih ramping */
    #step2-content input:not([type=checkbox]),
    #step2-content select,
    #step2-content textarea {
        background: var(--n-bg) !important;
        border-color: var(--n-line) !important;
        border-radius: var(--n-radius-sm) !important;
        padding: 8px 12px !important;
        font-size: 13px !important;
    }
    /* jarak antar-baris form dirapatkan */
    #step2-content form.space-y-6 > * + * { margin-top: 14px !important; }
    #step2-content .gap-4 { gap: 10px !important; }
    #step2-content .mb-6 { margin-bottom: 12px !important; }
    #step2-content .mb-8 { margin-bottom: 14px !important; }
    #step2-content .p-6 { padding: 14px !important; }
    /* judul & info dikecilkan */
    #step2-content h2 { font-size: 15px !important; }
    #step2-content h3 { font-size: 13px !important; margin-bottom: 10px !important; }
    /* buang aksen warna sisa → netral ink */
    #step2-content .text-emerald-400,
    #step2-content .text-blue-400,
    #step2-content .text-purple-400,
    #step2-content .text-amber-400 { color: var(--n-ink) !important; }
    #step2-content .text-emerald-400.font-mono,
    #step2-content code { color: var(--n-accent) !important; }
    #step2-content .bg-blue-500,
    #step2-content .bg-purple-500,
    #step2-content .bg-cyan-500,
    #step2-content .bg-emerald-500 { background: var(--n-ink) !important; }
</style>

<div class="animate-fade-in">
