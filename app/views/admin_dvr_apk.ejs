        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
                Tambah Kamera DVR/APK
            </h1>
            <p class="text-gray-500 text-sm mt-1">Tambahkan kamera CCTV/DVR dari berbagai merek dengan mudah. Masukkan username & password sesuai akun DVR/APK Anda.</p>
        </div>
    </div>

    <!-- ===== Layout 2 panel: kiri pilih merek, kanan form ===== -->
    <!-- Toggle baris info. Default COLLAPSE agar layar lega; pilihan disimpan
         di localStorage. Dibuka otomatis sekali saat user memilih merek, supaya
         "Informasi Merek" yang baru ter-render tidak terlewat. -->
    <button type="button" id="infoToggleBtn" onclick="toggleInfoRow()" class="n-btn n-btn-ghost mb-3" style="padding:7px 14px;">
        <svg id="infoToggleIcon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transition:transform .2s ease;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
        <span id="infoToggleText">Tampilkan Info &amp; Panduan</span>
    </button>

    <!-- BARIS INFO — full width DI ATAS kedua panel, 3 card sejajar. -->
    <!-- Proporsi: tengah (Tips) paling lebar agar tiap butir muat 1 baris;
         kanan (Protokol) paling sempit karena isinya pendek. -->
    <div id="info-row" class="hidden grid-cols-1 md:grid-cols-[1fr_1.6fr_0.9fr] gap-4 mb-4 items-stretch">
                <!-- Brand Info -->
