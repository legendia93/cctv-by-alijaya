<%- include('partials/admin_header', { title: 'Manajemen Pelanggan' }) %>
<%- include('partials/admin_sidebar', { page: 'customers' }) %>

<!-- Access Level Permission Matrix - Collapsible -->
<div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl border border-gray-700 mb-8">
    <!-- Collapse Header -->
    <div class="p-6 cursor-pointer select-none" onclick="toggleCollapse('permissionMatrix')">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    Level Akses & Permission Matrix
                </h2>
                <p class="text-[10px] text-gray-500 mt-1">Setiap level memiliki hak akses dan fitur berbeda terhadap kamera</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-[9px] text-gray-600 bg-gray-900 px-3 py-1.5 rounded-lg">v2.0</span>
                <button class="text-gray-400 hover:text-white transition" id="matrixToggleIcon">
                    <svg class="w-5 h-5 transition-transform duration-300" id="matrixArrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Collapsible Content -->
    <div id="permissionMatrix" class="px-6 pb-6 hidden">
        <!-- Matriks perbandingan: baris = fitur, kolom = level.
             Data diambil dari DB (/api/permissions/all) — sumber yang sama dengan
             menu Permission, jadi tidak bisa lagi out-of-sync. -->
        <div class="mb-3">
            <h3 class="text-xs font-black text-gray-300 uppercase tracking-widest">Matriks Perbandingan Level</h3>
            <p class="text-[10px] text-gray-400 mt-1">
                Arahkan mouse ke ikon &#9432; pada nama level untuk melihat deskripsi aksesnya.
                Nilai dibaca langsung dari pengaturan di menu <a href="<%= base_path %>/admin/permissions" class="underline hover:text-gray-200">Permission</a>.
            </p>
        </div>

        <!-- Pola tabel: transparan + garis tipis (docs/konteks/style-table.md) -->
        <style>
            .mtx-table td, .mtx-table th { background: transparent; }
            .mtx-table tbody tr.mtx-item td { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
            .mtx-table tbody tr.mtx-item:hover td { background: rgba(255, 255, 255, 0.035); }
            .mtx-table thead th { border-bottom: 1px solid rgba(255, 255, 255, 0.07); }
            .mtx-group td {
                background: rgba(255, 255, 255, 0.025);
                border-top: 1px solid rgba(255, 255, 255, 0.07);
                border-bottom: 1px solid rgba(255, 255, 255, 0.07);
            }
            /* Tooltip deskripsi level di header matriks. */
            .lvl-tip-box {
                position: absolute; top: calc(100% + 8px); left: 50%; transform: translateX(-50%);
                width: 220px; padding: 8px 10px; z-index: 30;
                background: #0b0b0d; border: 1px solid #374151; border-radius: 10px;
                color: #d1d5db; font-size: 10px; font-weight: 500; line-height: 1.5;
                text-transform: none; letter-spacing: normal; text-align: left;
                opacity: 0; visibility: hidden; transition: opacity .15s ease;
                box-shadow: 0 8px 24px rgba(0,0,0,.5); white-space: normal; pointer-events: none;
            }
            .lvl-tip:hover .lvl-tip-box { opacity: 1; visibility: visible; }
            @media (min-width: 640px) { #matrixTable { overflow: visible; } }
        </style>

        <div id="matrixTable" class="overflow-x-auto">
            <div class="text-center text-gray-400 text-xs py-6">Memuat data permission...</div>
        </div>

        <!-- Feature Details per Level - Collapsible -->
        <div class="mt-4 mb-2">
            <div class="flex items-center justify-between cursor-pointer" onclick="toggleCollapse('featureDetails')">
                <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest">🔍 Detail Fitur per Level</h3>
                <button class="text-gray-500 hover:text-white">
                    <svg class="w-4 h-4 transition-transform duration-300" id="featureDetailsArrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
            </div>
        </div>
        <div id="featureDetails" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-gray-900/50 rounded-xl border border-gray-700 p-4">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-6 h-6 rounded-lg bg-emerald-500/20 flex items-center justify-center text-emerald-400 text-xs font-black">F1</span>
                    <h4 class="text-[10px] font-black text-white uppercase tracking-widest">Stream Kamera</h4>
                </div>
                <ul class="text-[10px] space-y-1.5 text-gray-400">
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> UMUM: Hanya kamera level umum</li>
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> MEMBER: Kamera umum + kamera miliknya sendiri</li>
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> ADMIN: Semua kamera tanpa batasan</li>
                </ul>
            </div>
            <div class="bg-gray-900/50 rounded-xl border border-gray-700 p-4">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-6 h-6 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400 text-xs font-black">F2</span>
                    <h4 class="text-[10px] font-black text-white uppercase tracking-widest">Playback & Rekaman</h4>
                </div>
                <ul class="text-[10px] space-y-1.5 text-gray-400">
                    <li class="flex items-center gap-1.5"><span class="text-rose-500">✗</span> UMUM: Tidak bisa akses rekaman</li>
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> MEMBER: Rekaman sesuai level kamera</li>
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> ADMIN: Semua rekaman, bisa hapus</li>
                </ul>
            </div>
            <div class="bg-gray-900/50 rounded-xl border border-gray-700 p-4">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-6 h-6 rounded-lg bg-purple-500/20 flex items-center justify-center text-purple-400 text-xs font-black">F3</span>
                    <h4 class="text-[10px] font-black text-white uppercase tracking-widest">Catatan</h4>
                </div>
                <ul class="text-[10px] space-y-1.5 text-gray-400">
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> Kamera <strong class="text-gray-200">umum</strong> = komunal, terlihat semua level</li>
                    <li class="flex items-center gap-1.5"><span class="text-emerald-500">✓</span> Kamera non-umum = milik <strong class="text-gray-200">owner</strong>-nya saja</li>
                    <li class="flex items-center gap-1.5"><span class="text-amber-500">!</span> Hak akses per menu diatur di <strong class="text-gray-200">Permission</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Customer Modal (dibuka via tombol "Tambah Pelanggan") -->
<div id="customerModalBackdrop" class="fixed inset-0 z-[1000] bg-black/70 backdrop-blur-sm hidden items-start justify-center overflow-y-auto p-4 md:p-8" onclick="if(event.target===this) closeCustomerForm()">
<div class="bg-gray-800 rounded-2xl shadow-xl border border-gray-700 p-6 w-full max-w-4xl my-auto">
    <h2 class="text-xl font-bold mb-6 text-blue-400 border-b border-gray-700 pb-2 flex items-center justify-between gap-2">
        <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <span id="formTitle">Tambah Pelanggan Baru</span>
        </span>
        <button type="button" onclick="closeCustomerForm()" class="text-gray-400 hover:text-white p-1.5 rounded-lg hover:bg-gray-700/50 transition" title="Tutup (Esc)">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </h2>

    <form id="customerForm" action="<%= base_path %>/admin/users/add" method="POST" class="space-y-6">
        <input type="hidden" name="id" id="edit_user_id">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Username</label>
                <input type="text" name="username" id="edit_username" required class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all" placeholder="Contoh: rudi_cctv">
            </div>
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Password</label>
                <input type="password" name="password" id="edit_password" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all" placeholder="Isi hanya jika ingin ganti password">
                <p id="passHint" class="hidden text-[9px] text-gray-500 mt-1 italic">* Kosongkan jika tidak ingin mengubah password</p>
            </div>
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Level Akses</label>
                <select name="level" id="edit_level" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all">
                    <option value="umum">UMUM (Gratis) - Kamera umum saja</option>
                    <option value="member">MEMBER - Kamera umum + kamera miliknya + rekaman</option>
                    <option value="admin">ADMIN (Full Control) - Manajemen sistem</option>
                </select>
                <p id="levelDescription" class="text-[9px] text-gray-500 mt-1">Tips: Arahkan mouse ke level untuk melihat deskripsi akses</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Nama Lengkap</label>
                <input type="text" name="full_name" id="edit_full_name" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all" placeholder="Nama asli pelanggan">
            </div>
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">No. WhatsApp / HP</label>
                <input type="text" name="phone" id="edit_phone" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all" placeholder="0812xxxx">
            </div>
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Masa Aktif Hingga</label>
                <input type="date" name="active_until" id="edit_active_until" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all">
                <p class="text-[9px] text-gray-500 mt-1 italic">* Kosongkan untuk akses selamanya</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Email (Opsional)</label>
                <input type="email" name="email" id="edit_email" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all" placeholder="email@example.com">
            </div>
            <div>
                <label class="block text-[10px] font-black text-gray-500 mb-2 uppercase tracking-widest">Alamat Lengkap</label>
                <textarea name="address" id="edit_address" rows="1" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:border-blue-500 transition-all" placeholder="Alamat pemasangan atau domisili..."></textarea>
            </div>
        </div>

        <div class="flex justify-end gap-3">
            <button type="button" id="cancelBtn" onclick="closeCustomerForm()" class="bg-gray-700 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-xl transition uppercase text-xs tracking-widest">Batal</button>
            <button type="submit" id="submitBtn" class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-8 rounded-xl shadow-xl shadow-blue-900/20 transition transform active:scale-95 uppercase text-xs tracking-widest">
                Simpan Pelanggan
            </button>
        </div>
    </form>
</div>
</div>

<!-- Customer List -->
<div class="bg-gray-800 rounded-2xl shadow-xl border border-gray-700 overflow-hidden">
    <div class="p-6 border-b border-gray-700 flex justify-between items-center">
        <h2 class="text-lg font-bold text-white uppercase tracking-wider">Daftar Pelanggan Terdaftar</h2>
        <div class="flex items-center gap-3">
            <button type="button" onclick="openCustomerForm()" class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-2 px-4 rounded-xl transition transform active:scale-95 flex items-center gap-2 whitespace-nowrap shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                <span class="text-[10px] uppercase tracking-widest">Tambah Pelanggan</span>
            </button>
            <div class="relative">
                <input type="text" id="userSearch" placeholder="Cari pelanggan..." class="bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-xs text-white focus:border-blue-500 transition-all pl-10">
                <svg class="w-4 h-4 text-gray-500 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <span class="text-[10px] font-black text-gray-500 bg-gray-900 px-3 py-1 rounded-lg uppercase tracking-widest"><%= users.length %> Pelanggan</span>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead>
                <tr class="text-gray-500 uppercase text-[10px] tracking-widest border-b border-gray-700 bg-gray-900/50 font-black">
                    <th class="p-4">Identitas</th>
                    <th class="p-4">Kontak</th>
                    <th class="p-4">Level</th>
                    <th class="p-4">Permission</th>
                    <th class="p-4">Masa Aktif</th>
                    <th class="p-4 text-right">Aksi</th>
                </tr>
            </thead>
            <tbody id="userTableBody" class="divide-y divide-gray-700/50">
                <% users.forEach(function(u) { %>
                    <tr class="hover:bg-gray-700/30 transition group">
                        <td class="p-4">
                            <div class="font-bold text-white text-sm"><%= u.full_name || u.username %></div>
                            <div class="text-[10px] text-gray-500 font-mono tracking-tight">@<%= u.username %></div>
                        </td>
                        <td class="p-4">
                            <% if (u.phone) { %>
                                <div class="text-xs text-gray-300 flex items-center gap-1">
                                    <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.414 0 0 5.414 0 12.05c0 2.123.552 4.197 1.6 6.037L0 24l6.105-1.602a11.834 11.834 0 005.937 1.598h.005c6.637 0 12.05-5.414 12.05-12.05a11.852 11.852 0 00-3.682-8.491z"/></svg>
                                    <%= u.phone %>
                                </div>
                            <% } %>
                            <% if (u.email) { %>
                                <div class="text-[10px] text-gray-500 truncate max-w-[150px]"><%= u.email %></div>
                            <% } %>
                        </td>
                        <td class="p-4">
                            <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest border
                                <%= u.level === 'admin' ? 'bg-emerald-900/40 text-emerald-400 border-emerald-500/20' : 
                                    u.level === 'vvip' ? 'bg-amber-900/40 text-amber-400 border-amber-500/20' : 
                                    u.level === 'pemerintahan' ? 'bg-cyan-900/40 text-cyan-400 border-cyan-500/20' :
                                    u.level === 'vip' ? 'bg-amber-900/30 text-amber-300 border-amber-500/10' :
                                    u.level === 'member' ? 'bg-blue-900/40 text-blue-400 border-blue-500/20' :
                                    'bg-gray-700 text-gray-400 border-gray-600/30' %>">
                                <%= (u.level || 'umum').toUpperCase() %>
                            </span>
                        </td>
                        <td class="p-4">
                            <div class="flex items-center gap-1">
                                <% 
                                    const level = (u.level || 'umum').toLowerCase();
                                    const icons = {
                                        admin: ['🔒','🔑','📹','📼','💰','🤖'],
                                        vvip: ['📹','📼','📊','🌤️','🏆'],
                                        pemerintahan: ['📹','📼','📊','🌤️','🏛️'],
                                        vip: ['📹','📼','📊','🌤️'],
                                        member: ['📹','📼','📊'],
                                        umum: ['📹','📊']
                                    };
                                    (icons[level] || ['📹']).forEach(function(icon) { 
                                %>
                                    <span class="text-xs" title="<%= icon %>"><%= icon %></span>
                                <% }); %>
                            </div>
                        </td>
                        <td class="p-4">
                            <% if (u.active_until) { %>
                                <% 
                                    const expiry = new Date(u.active_until);
                                    const now = new Date();
                                    const isExpired = expiry < now;
                                %>
                                <div class="flex flex-col">
                                    <span class="text-xs <%= isExpired ? 'text-rose-500 font-bold' : 'text-emerald-400' %>">
                                        <%= expiry.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                    </span>
                                    <span class="text-[9px] uppercase tracking-tighter <%= isExpired ? 'text-rose-700' : 'text-gray-500' %>">
                                        <%= isExpired ? 'Expired' : 'Aktif' %>
                                    </span>
                                </div>
                            <% } else { %>
                                <span class="text-[10px] text-gray-500 italic">Selamanya</span>
                            <% } %>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition">
                                <button onclick='editUser(<%- JSON.stringify(u) %>)' class="text-blue-400 hover:bg-blue-400/10 p-2 rounded-xl transition" title="Edit">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </button>
                                <button onclick="deleteUser('<%= u.id %>')" class="text-rose-500 hover:bg-rose-500/10 p-2 rounded-xl transition" title="Hapus">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<script>
    // Collapse/Expand Function
    function toggleCollapse(id) {
        const el = document.getElementById(id);
        const arrow = document.getElementById(id + 'Arrow');
        if (!el) return;
        el.classList.toggle('hidden');
        if (arrow) arrow.style.transform = el.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';

        // Matriks di-load saat pertama kali panel dibuka (hemat 1 request).
        if (id === 'permissionMatrix' && !el.classList.contains('hidden') && !matrixLoaded) {
            loadMatrix();
        }
    }

    /* ===== Matriks permission (dibaca dari DB, bukan hardcode) ===== */
    let matrixLoaded = false;

    // Level yang ditampilkan sebagai kolom, urut dari akses terendah.
    const MTX_LEVELS = ['umum', 'member', 'admin'];
    const mtxBadge = {
        umum: 'bg-gray-700 text-gray-300 border-gray-600/50',
        member: 'bg-blue-900/40 text-blue-400 border-blue-500/30',
        admin: 'bg-emerald-900/40 text-emerald-400 border-emerald-500/30'
    };
    const mtxDesc = {
        umum: 'Akses dasar — hanya bisa melihat stream kamera umum, melaporkan kejadian & info cuaca.',
        member: 'Akses menengah — kamera umum + kamera miliknya sendiri, playback rekaman, laporan & cuaca.',
        admin: 'Full control — semua fitur dan manajemen sistem, kamera, pengguna, billing, dll.'
    };

    // Pengelompokan & label disamakan dengan menu Permission.
    // Grup "Admin Panel" sengaja TIDAK ditampilkan: seluruh menunya memang khusus
    // admin, jadi barisnya selalu ✗ ✗ ✓ dan tak menambah informasi. Untuk mengaturnya
    // gunakan menu Permission.
    const mtxGroups = {
        'Streaming': ['camera_preview','camera_playback','camera_embed','camera_map'],
        'Data & Informasi': ['recordings','incident_reports','incident_create','weather_view','weather_marine'],
        'Akun Pengguna': ['user_account','user_billing','push_notifications']
    };
    const mtxLabels = {
        camera_preview: 'Preview Kamera', camera_playback: 'Playback Rekaman',
        camera_embed: 'Embed Kamera', camera_map: 'Peta Kamera',
        recordings: 'Arsip Rekaman', incident_reports: 'Laporan Kejadian',
        incident_create: 'Buat Laporan', weather_view: 'Info Cuaca',
        weather_marine: 'Cuaca Marine', user_account: 'Akun Saya',
        user_billing: 'Billing & Paket', push_notifications: 'Notifikasi Push'
    };

    function mtxEsc(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    async function loadMatrix() {
        const box = document.getElementById('matrixTable');
        if (!box) return;
        try {
            const res = await fetch('<%= base_path %>/api/permissions/all');
            const data = await res.json();
            if (!data.success) throw new Error(data.error || 'Gagal memuat');
            matrixLoaded = true;
            renderMatrix(data.permissions || {});
        } catch (e) {
            box.innerHTML = '<div class="text-center text-rose-400 text-xs py-6">Gagal memuat data permission: ' + mtxEsc(e.message) + '</div>';
        }
    }

    function renderMatrix(perms) {
        let html = '<table class="mtx-table w-full text-xs min-w-[420px]">';

        html += '<thead><tr>';
        html += '<th class="px-3 py-2 text-left text-[9px] uppercase tracking-widest font-black text-gray-300">Fitur</th>';
        MTX_LEVELS.forEach(function (lv) {
            html += '<th class="px-3 py-2 text-center">';
            html += '<span class="lvl-tip relative inline-flex items-center gap-1 px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest border cursor-help ' + mtxBadge[lv] + '">';
            html += lv + '<span class="opacity-60">&#9432;</span>';
            html += '<span class="lvl-tip-box">' + mtxEsc(mtxDesc[lv] || '') + '</span>';
            html += '</span></th>';
        });
        html += '</tr></thead><tbody>';

        Object.keys(mtxGroups).forEach(function (group) {
            html += '<tr class="mtx-group"><td class="px-3 py-2">';
            html += '<span class="text-[9px] font-black text-gray-100 uppercase tracking-widest">' + mtxEsc(group) + '</span>';
            html += '</td>';
            MTX_LEVELS.forEach(function (lv) {
                const p = perms[lv] || {};
                const ids = mtxGroups[group];
                const on = ids.filter(function (id) { return p[id] === true; }).length;
                html += '<td class="px-3 py-2 text-center text-[9px] text-gray-300 tabular-nums">' + on + '/' + ids.length + '</td>';
            });
            html += '</tr>';

            mtxGroups[group].forEach(function (id) {
                html += '<tr class="mtx-item">';
                html += '<td class="px-3 py-2 text-gray-50">' + mtxEsc(mtxLabels[id] || id) + '</td>';
                MTX_LEVELS.forEach(function (lv) {
                    const ok = (perms[lv] || {})[id] === true;
                    html += '<td class="px-3 py-2 text-center">';
                    html += ok
                        ? '<span class="text-emerald-400 text-sm font-bold" title="Bisa diakses">&#10003;</span>'
                        : '<span class="text-rose-500/60 text-sm font-bold" title="Tidak bisa diakses">&#10007;</span>';
                    html += '</td>';
                });
                html += '</tr>';
            });
        });

        html += '</tbody></table>';

        html += '<div class="flex flex-wrap items-center gap-4 mt-3 pt-3 text-[10px] text-gray-300" style="border-top:1px solid rgba(255,255,255,0.07);">';
        html += '<span class="flex items-center gap-1.5"><span class="text-emerald-400 font-bold">&#10003;</span> Bisa diakses</span>';
        html += '<span class="flex items-center gap-1.5"><span class="text-rose-500/60 font-bold">&#10007;</span> Tidak bisa diakses</span>';
        html += '<span class="text-gray-500">Menu Admin Panel tidak ditampilkan &mdash; khusus level admin.</span>';
        html += '</div>';

        document.getElementById('matrixTable').innerHTML = html;
    }

    // Level descriptions for dropdown
    const levelDescriptions = {
        'umum': '📹 Hanya bisa melihat stream kamera umum. Tidak bisa akses rekaman.',
        'member': '📹📼 Bisa melihat kamera umum + member + mengakses rekaman playback.',
        'vip': '📹📼📊🌤️ Semua fitur member + VIP. Akses kamera VIP eksklusif.',
        'vvip': '📹📼📊🌤️🏆 Super prioritas. Akses semua level + kamera VVIP pribadi.',
        'pemerintahan': '📹📼📊🌤️🏛️ Akses kamera khusus pemerintahan + semua level dasar.',
        'admin': '🔒🔑📹📼💰🤖 Full control manajemen sistem, kamera, pengguna, billing, AI.'
    };

    document.getElementById('edit_level').addEventListener('change', function() {
        const desc = levelDescriptions[this.value] || '';
        document.getElementById('levelDescription').innerText = desc;
        document.getElementById('levelDescription').className = 'text-[9px] text-cyan-400/70 mt-1';
    });

    function editUser(user) {
        document.getElementById('edit_user_id').value = user.id;
        document.getElementById('edit_username').value = user.username;
        document.getElementById('edit_level').value = user.level;
        document.getElementById('edit_full_name').value = user.full_name || '';
        document.getElementById('edit_phone').value = user.phone || '';
        document.getElementById('edit_email').value = user.email || '';
        document.getElementById('edit_address').value = user.address || '';
        
        if (user.active_until) {
            const date = new Date(user.active_until);
            document.getElementById('edit_active_until').value = date.toISOString().split('T')[0];
        } else {
            document.getElementById('edit_active_until').value = '';
        }

        document.getElementById('formTitle').innerText = 'Edit Pelanggan: ' + (user.full_name || user.username);
        document.getElementById('submitBtn').innerText = 'Update Pelanggan';
        document.getElementById('customerForm').action = '<%= base_path %>/admin/users/edit';
        document.getElementById('passHint').classList.remove('hidden');
        document.getElementById('edit_password').required = false;
        
        // Show level description
        const desc = levelDescriptions[user.level] || '';
        document.getElementById('levelDescription').innerText = desc;
        document.getElementById('levelDescription').className = 'text-[9px] text-cyan-400/70 mt-1';
        
        openCustomerModal();
    }

    /* ===== Modal tambah/edit pelanggan ===== */
    function openCustomerModal() {
        const b = document.getElementById('customerModalBackdrop');
        b.classList.remove('hidden'); b.classList.add('flex');
    }

    // Tombol "Tambah Pelanggan": reset form ke mode tambah, lalu buka modal.
    function openCustomerForm() {
        resetCustomerForm();
        openCustomerModal();
    }

    function closeCustomerForm() {
        const b = document.getElementById('customerModalBackdrop');
        b.classList.add('hidden'); b.classList.remove('flex');
        resetCustomerForm();
    }

    function resetCustomerForm() {
        document.getElementById('customerForm').reset();
        document.getElementById('edit_user_id').value = '';
        document.getElementById('formTitle').innerText = 'Tambah Pelanggan Baru';
        document.getElementById('submitBtn').innerText = 'Simpan Pelanggan';
        document.getElementById('customerForm').action = '<%= base_path %>/admin/users/add';
        document.getElementById('passHint').classList.add('hidden');
        document.getElementById('edit_password').required = true;
        document.getElementById('levelDescription').innerText = 'Tips: Pilih level untuk melihat deskripsi akses';
        document.getElementById('levelDescription').className = 'text-[9px] text-gray-500 mt-1';
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !document.getElementById('customerModalBackdrop').classList.contains('hidden')) closeCustomerForm();
    });

    async function deleteUser(id) {
        showModal("Hapus pelanggan ini secara permanen?", "confirm", async () => {
            const res = await fetch('<%= base_path %>/admin/users/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            if (res.ok) window.location.reload();
        });
    }

    document.getElementById('userSearch').oninput = function() {
        const q = this.value.toLowerCase();
        const rows = document.querySelectorAll('#userTableBody tr');
        rows.forEach(row => {
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(q) ? '' : 'none';
        });
    };
</script>

<%- include('partials/admin_footer') %>